rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /sessions/{sessionId} {
      allow read, create, update: if isOwner(resource.data.userId) || isOwner(request.resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }

    match /results/{resultId} {
      allow read, create, update: if isOwner(resource.data.userId) || isOwner(request.resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }

    match /shares/{shareId} {
      allow read: if resource.data.status == "active" && resource.data.expiresAt > request.time;
      allow create, update, delete: if isOwner(resource.data.userId) || isOwner(request.resource.data.userId);
    }

    match /catalog/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /ops/{document=**} {
      allow read, write: if false;
    }
  }
}
